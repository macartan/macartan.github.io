dat <- data.frame(
x = c(0, runif(99, 0, 100)),
y = c(0, runif(99, 0, 100))
)
ggplot(dat, aes(x, y)) +
geom_point() +
scale_x_sqrt() +
scale_y_sqrt() +
coord_equal()
library(tidyverse)
dat <- tribble(
~Day, ~Time, ~Panels, ~Attendees, ~Papers, ~AttendeesPerPaper,
"Thursday", "09:00", 20, 24.5, 4.5, 5.0,
"Thursday", "10:50", 21, 36.0, 4.2, 8.0,
"Thursday", "13:30", 22, 32.1, 4.5, 7.1,
"Thursday", "15:20", 21, 27.8, 4.4, 6.3,
"Thursday", "17:10", 19, 22.2, 4.5, 4.9,
"Friday",   "09:00", 22, 20.1, 4.3, 4.7,
"Friday",   "10:50", 23, 27.7, 4.8, 6.4,
"Friday",   "13:30", 23, 29.3, 4.9, 6.0,
"Friday",   "15:20", 23, 32.0, 4.6, 7.6,
"Friday",   "17:10", 22, 21.9, 4.6, 4.8,
"Saturday", "09:00", 19, 18.0, 4.9, 3.7,
"Saturday", "10:50", 21, 20.6, 4.4, 4.7,
"Saturday", "13:30", 19, 23.8, 4.6, 5.1,
"Saturday", "15:20", 17, 20.9, 4.5, 4.6
)
dat <- dat |>
mutate(
DateTime = as.POSIXct(
paste(
c("2025-01-02", "2025-01-03", "2025-01-04")[match(Day, c("Thursday", "Friday", "Saturday"))],
Time
)
)
)
ggplot(dat, aes(DateTime, AttendeesPerPaper)) +
geom_line() +
geom_point() +
labs(
x = NULL,
y = "Attendees per paper"
) +
theme_minimal()
